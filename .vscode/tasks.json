{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake Configure",
      "type": "shell",
      "command": "cmake",
      "args": ["-S", ".", "-B", "build", "-G", "Visual Studio 17 2022", "-A", "x64"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Build (Release)",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "build", "--config", "Release", "--parallel"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Deploy",
      "type": "shell",
      "command": "cmd",
      "args": ["/c", "install.bat"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Build & Deploy (Release)",
      "dependsOrder": "sequence",
      "dependsOn": ["Build (Release)", "Deploy"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Build chat_translator (Hot Reload)",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "build", "--config", "Release", "--target", "chat_translator", "--parallel"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Toggle Mod (Enable/Disable)",
      "type": "shell",
      "command": "cmd",
      "args": ["/c", "toggle_mod.bat"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Uninstall",
      "type": "shell",
      "command": "cmd",
      "args": ["/c", "uninstall.bat"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Run Translate Test Tool",
      "type": "shell",
      "command": "C:\\src\\2dtest2\\.venv\\Scripts\\python.exe",
      "args": ["./tools/translate_test.py"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Run TTS Test Tool",
      "type": "shell",
      "command": "python",
      "args": ["${workspaceFolder}\\tools\\tts_test.py"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Build Overlay Test",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "build", "--config", "Release", "--target", "overlay_test", "--parallel"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared"
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Run Overlay Test",
      "type": "shell",
      "command": "Start-Process",
      "args": ["${workspaceFolder}\\build\\overlay_test\\overlay_test.exe"],
      "options": {
        "cwd": "${workspaceFolder}\\build\\overlay_test"
      },
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Build & Run Overlay Test",
      "dependsOrder": "sequence",
      "dependsOn": ["Build Overlay Test", "Run Overlay Test"],
      "problemMatcher": []
    }
  ]
}
